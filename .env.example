# Server
PORT=3000

# Admin credentials — change before deploying to production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# JWT — use a long random string in production
JWT_SECRET=longxiang-local-dev-secret-2024

# CORS — comma-separated allowed origins; leave unset to allow all (dev only)
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# SMTP for inquiry email notifications (optional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@example.com
# INQUIRY_NOTIFY_TO=admin@example.com
